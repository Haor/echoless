{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Echoless",
  "version": "0.1.0",
  "identifier": "app.echoless.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm prepare:tauri-assets --dev && pnpm dev",
    "beforeBuildCommand": "pnpm prepare:tauri-assets && pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/echoless"
    ],
    "resources": [
      "resources/"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
